function SpectatePlayer(player)
    S.SpectatingPlayer = player
    S.spectating = true
    if S.specConnection then
        S.specConnection:Disconnect()
        S.specConnection = nil
    end
    local function setCamera(character)
        if not S.spectating then return end
        local humanoid = character:WaitForChild("Humanoid")
        Camera.CameraSubject = humanoid
    end
    if player.Character then
        setCamera(player.Character)
    end
    S.specConnection = player.CharacterAdded:Connect(function(char)
        if S.spectating then
            setCamera(char)
        end
    end)
end
function StopSpectate()
    S.spectating = false
    S.SpectatingPlayer = nil
    if S.specConnection then
        S.specConnection:Disconnect()
        S.specConnection = nil
    end
    if S.selectedSpecButton then
        S.selectedSpecButton.BackgroundColor3 = Color3.fromRGB(70,70,70)
        S.selectedSpecButton = nil
    end
    if LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            Camera.CameraSubject = humanoid
        end
    end
end
