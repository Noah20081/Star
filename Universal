local function onCharacterReady(player, character)
    if not character then return end
    local humanoid = character:WaitForChild("Humanoid", 10)
    local head     = character:WaitForChild("Head", 10)
    local hrp      = character:WaitForChild("HumanoidRootPart", 10)
    if not humanoid or not head or not hrp then return end
    repeat task.wait(0.1) until humanoid.Health > 0 or not character.Parent
    if not character.Parent or humanoid.Health <= 0 then return end
    local size = tonumber(S.sizeInput and S.sizeInput.Text) or DEFAULT_HITBOX_SIZE
    if S.autoHitboxEnabled    then pcall(applyHeadHitbox,  player, character, size)          end
    if S.autoBodyHitboxEnabled then pcall(applyBodyHitbox, character, size)                  end
    if S.boxESPEnabled         then pcall(addBoxESP, character, getTeamColor(player), size)  end
    if S.espShowName or S.espShowDist or S.espShowHp or (S.nameESPEnabled and S.selectedPlayers[player]) then
        pcall(createNameESP, player, character)
    end
    if S.chamsEnabled then pcall(addChams, character, getTeamColor(player)) end
    if S.tracerESPEnabled then pcall(createTracerESP, player) end
    humanoid.Died:Connect(function()
        S.processedChars[character] = nil
        removeHeadHitbox(character)
        removeOutlineChams(character)
        resetBodyHitbox(character)
        removeBoxESP(character)
        removeNameESP(player)
        removeChams(character)
        removeTracerESP(player)
        task.spawn(function()
            while character and character.Parent do
                pcall(resetBodyHitbox, character)
                task.wait(0.5)
            end
        end)
    end)
    character.AncestryChanged:Connect(function(_, parent)
        if not parent then
            S.processedChars[character] = nil
            removeHeadHitbox(character)
            removeOutlineChams(character)
            resetBodyHitbox(character)
            removeBoxESP(character)
            removeChams(character)
        end
    end)
end
local function registerPlayer(player)
    if player == LocalPlayer then return end
    if S.playerConnections[player] then return end
    S.playerConnections[player] = {}
    task.spawn(function()
        local lastChar = nil
        while player.Parent do
            local char = player.Character
            if char and char ~= lastChar then
                lastChar = char
                S.processedChars[char] = nil
                task.spawn(onCharacterReady, player, char)
            end
            task.wait(0.5)
        end
    end)
end
