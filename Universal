local function _aimFriend(player)
    if not AimSettings.FriendCheck then return false end
    local cached = AimFriendCache[player.UserId]
    if cached ~= nil then
        return cached
    end
    local isFriend = false
    local ok, res = pcall(function()
        return LocalPlayer:IsFriendsWith(player.UserId)
    end)
    if ok and res then
        isFriend = true
    elseif player:GetAttribute("Friendly") == true then
        isFriend = true
    end
    AimFriendCache[player.UserId] = isFriend
    return isFriend
end
    local function _aimHasFF(char)
        if not AimSettings.ForceFieldCheck then return false end
        if char:FindFirstChildOfClass("ForceField") then return true end
        return char:GetAttribute("SpawnProtected") == true
    end
    local function _aimCanSee(part, char)
        if not AimSettings.WallCheck then return true end
        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Exclude
        rp.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
        rp.IgnoreWater = true
        local result = workspace:Raycast(
            Camera.CFrame.Position,
            part.Position - Camera.CFrame.Position,
            rp
        )
        if result then return result.Instance:IsDescendantOf(char) end
        return true
    end
    local function _getClosest()
        local closest, shortest = nil, AimSettings.FOV
        local cx = Camera.ViewportSize.X / 2 + AimSettings.FOVOffsetX
        local cy = Camera.ViewportSize.Y / 2 + AimSettings.FOVOffsetY
        for _, p in ipairs(Players:GetPlayers()) do
            if p == LocalPlayer then continue end
            if AimSettings.TeamCheck and LocalPlayer.Team ~= nil and p.Team == LocalPlayer.Team then continue end
            if _aimFriend(p) then continue end
            local char = p.Character
            if char and _aimAlive(char) then
                if _aimHasFF(char) then continue end
                local hum  = char:FindFirstChildOfClass("Humanoid")
                local part = char:FindFirstChild(AimSettings.AimPart)
                if hum and part then
                    if AimSettings.HPCheck and hum.Health <= 0 then continue end
                    if not _aimCanSee(part, char) then continue end
                    local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local d = (Vector2.new(sp.X, sp.Y) - Vector2.new(cx, cy)).Magnitude
                        if d < shortest then shortest = d; closest = part end
                    end
                end
            end
        end
        return closest
    end
    local function _aimAt(part)
        if not part then return end
        local pos = part.Position
        if AimSettings.Prediction then
            local vel = Vector3.zero
            pcall(function() vel = part.AssemblyLinearVelocity end)
            if vel.Magnitude <= 0.05 then pcall(function() vel = part.Velocity end) end
            local t = AimSettings.PredictionAmount
            if AimSettings.AirPrediction and math.abs(vel.Y) > 2 then
                t = AimSettings.AirPredictionAmount
            end
            pos = pos + vel * t
        end
        Camera.CFrame = Camera.CFrame:Lerp(
            CFrame.new(Camera.CFrame.Position, pos),
            AimSettings.Smoothness
        )
    end
 local currentAimTarget = nil
local lastAimScan = 0
local AIM_SCAN_INTERVAL = 0.05
local SWITCH_THRESHOLD = 40
local function _isTargetValid(part)
    if not part or not part.Parent then return false end
    local char = part.Parent
    if not _aimAlive(char) then return false end
    if _aimHasFF(char) then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or (AimSettings.HPCheck and hum.Health <= 0) then return false end
    if not _aimCanSee(part, char) then return false end
    local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
    if not onScreen then return false end
    local cx = Camera.ViewportSize.X / 2 + AimSettings.FOVOffsetX
    local cy = Camera.ViewportSize.Y / 2 + AimSettings.FOVOffsetY
    local d = (Vector2.new(sp.X, sp.Y) - Vector2.new(cx, cy)).Magnitude
    return d < AimSettings.FOV
end
RunService.RenderStepped:Connect(function()
    local vs = Camera.ViewportSize
    FOVCircleAim.Position = UDim2.new(
        0, vs.X / 2 + AimSettings.FOVOffsetX,
        0, vs.Y / 2 + AimSettings.FOVOffsetY
    )
    FOVCircleAim.Size    = UDim2.new(0, AimSettings.FOV * 2, 0, AimSettings.FOV * 2)
    FOVCircleAim.Visible = AimSettings.ShowFOV
    if not AimSettings.AimEnabled then
        currentAimTarget = nil
        return
    end
    if tick() - lastAimScan >= AIM_SCAN_INTERVAL then
        lastAimScan = tick()
        if currentAimTarget and _isTargetValid(currentAimTarget) then
            local sp_cur = Camera:WorldToViewportPoint(currentAimTarget.Position)
            local cx = Camera.ViewportSize.X / 2 + AimSettings.FOVOffsetX
            local cy = Camera.ViewportSize.Y / 2 + AimSettings.FOVOffsetY
            local curDist = (Vector2.new(sp_cur.X, sp_cur.Y) - Vector2.new(cx, cy)).Magnitude
            local newTarget, newDist = _getClosest(), math.huge
            if newTarget then
                local sp_new = Camera:WorldToViewportPoint(newTarget.Position)
                newDist = (Vector2.new(sp_new.X, sp_new.Y) - Vector2.new(cx, cy)).Magnitude
            end
            if newTarget and newTarget ~= currentAimTarget and (curDist - newDist) >= SWITCH_THRESHOLD then
                currentAimTarget = newTarget
            end
        else
            currentAimTarget = _getClosest()
        end
    end
    _aimAt(currentAimTarget)
end)
