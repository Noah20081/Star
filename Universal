local SAVED_POS_FILE = "StarCrow/SavedPositions.json"
local function loadSavedPositions()
    if not (readfile and writefile) then return {} end
    local ok, data = pcall(readfile, SAVED_POS_FILE)
    if not ok or not data or data == "" then return {} end
    local decoded = {}
    for name, t in next, (game:GetService("HttpService"):JSONDecode(data) or {}) do
        decoded[name] = CFrame.new(
            t[1], t[2], t[3],
            t[4], t[5], t[6],
            t[7], t[8], t[9],
            t[10], t[11], t[12]
        )
    end
    return decoded
end
local function saveSavedPositions(tbl)
    if not (readfile and writefile) then return end
    local raw = {}
    for name, cf in next, tbl do
        raw[name] = {
            cf.X, cf.Y, cf.Z,
            cf.XVector.X, cf.XVector.Y, cf.XVector.Z,
            cf.YVector.X, cf.YVector.Y, cf.YVector.Z,
            cf.ZVector.X, cf.ZVector.Y, cf.ZVector.Z
        }
    end
    pcall(writefile, SAVED_POS_FILE, game:GetService("HttpService"):JSONEncode(raw))
end
