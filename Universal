local function findUseTool(name)
    local low = name:lower()
    local char = LocalPlayer.Character
    for _, v in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower() == low then return v end
    end
    if char then
