S.floatDragLocked = false
local function makeDraggableFloat(btn)
    local fDragging = false
    local fMoved = false
    local fDragStart = nil
    local fDragPos = nil
    local fDragInput = nil
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            if S.floatDragLocked then
                fDragging = false
                fDragInput = nil
                return
            end
            fDragging = true
            fMoved = false
            fDragStart = input.Position
            fDragPos = btn.Position
            fDragInput = input
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    fDragging = false
                    fDragInput = nil
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if S.floatDragLocked then
            return
        end
        if fDragging and (
            input == fDragInput or
            input.UserInputType == Enum.UserInputType.MouseMovement
        ) then
            local delta = input.Position - fDragStart
            if delta.Magnitude > 6 then fMoved = true end
            btn.Position = UDim2.new(
                fDragPos.X.Scale, fDragPos.X.Offset + delta.X,
                fDragPos.Y.Scale, fDragPos.Y.Offset + delta.Y
            )
        end
    end)
    return function() return fMoved end, function() fMoved = false end
end
