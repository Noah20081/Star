local function applyHeadHitbox(player, character, size)
    if not player or not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        if S.processedChars[character] then
            removeHeadHitbox(character)
        end
        return
    end
    local head = character:FindFirstChild("Head")
    if not head then return end
    local teamColor = getTeamColor(player)
    local targetSize = Vector3.new(size, size, size)
    if humanoid.Health <= 0 then
        if S.processedChars[character] then
            removeHeadHitbox(character)
        end
        return
    end
    if not head:FindFirstChild("OriginalSize") then
        local sv = Instance.new("Vector3Value")
        sv.Name = "OriginalSize"
        sv.Value = head.Size
        sv.Parent = head
    end
    if not head:FindFirstChild("OriginalColor") then
        local cv = Instance.new("Color3Value")
        cv.Name = "OriginalColor"
        cv.Value = head.Color
        cv.Parent = head
    end
    local meshBackup = head:FindFirstChild("__MeshBackup")
    if not meshBackup then
        local existingMesh = head:FindFirstChildOfClass("SpecialMesh") or head:FindFirstChildOfClass("BlockMesh")
        if existingMesh then
            local folder = Instance.new("Folder")
            folder.Name = "__MeshBackup"
            folder.Parent = head
            existingMesh:Clone().Parent = folder
            existingMesh:Destroy()
        end
    else
        local strayMesh = head:FindFirstChildOfClass("SpecialMesh") or head:FindFirstChildOfClass("BlockMesh")
        if strayMesh then
            strayMesh:Destroy()
        end
    end
    if humanoid.Health <= 0 then
        removeHeadHitbox(character)
        return
    end
    local needsRefresh =
        head.Size ~= targetSize
        or head.Transparency < 0.45 or head.Transparency > 0.55
        or head.Material ~= Enum.Material.ForceField
        or head.CanCollide ~= false
        or head.Massless ~= true
        or head.Color ~= teamColor
    if needsRefresh then
        head.Massless = true
        head.Size = targetSize
        head.CanCollide = false
        head.Transparency = 0.5
        head.Material = Enum.Material.ForceField
        head.Color = teamColor
    end
    if not character:FindFirstChild("StarCrowOutline") then
        addOutlineChams(character)
    end
    if not character:FindFirstChild("__HeadHitboxDeathHook") then
        local tag = Instance.new("BoolValue")
        tag.Name = "__HeadHitboxDeathHook"
        tag.Parent = character
        humanoid.Died:Connect(function()
            if character and character.Parent then
                removeHeadHitbox(character)
            end
        end)
        humanoid:GetPropertyChangedSignal("Health"):Connect(function()
            if humanoid.Health <= 0 then
                if character and character.Parent then
                    removeHeadHitbox(character)
                end
            end
        end)
        task.spawn(function()
            while true do
                task.wait(0.5)
                if not character or not character.Parent then
                    task.wait(2)
                    if not character or not character.Parent then break end
                end
                if not S.autoHitboxEnabled then break end
                if not S.processedChars[character] then break end
                local currentHumanoid = character:FindFirstChildOfClass("Humanoid")
                if not currentHumanoid or currentHumanoid.Health <= 0 then break end
                if not character:FindFirstChild("StarCrowOutline") then
                    addOutlineChams(character)
                end
            end
        end)
    end
    S.processedChars[character] = true
end
