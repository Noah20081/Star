    sizeValueLabel.TextXAlignment         = Enum.TextXAlignment.Right
    sizeValueLabel.Parent                 = sizeLabelRow
    local sliderWrapper = Instance.new("Frame")
    sliderWrapper.Size                   = UDim2.new(1, 0, 0, 20)
    sliderWrapper.BackgroundTransparency = 1
    sliderWrapper.BorderSizePixel        = 0
    sliderWrapper.Active                 = true
    sliderWrapper.Parent                 = panelRef
    local trackBg = Instance.new("Frame")
    trackBg.Size                   = UDim2.new(1, 0, 0, 6)
    trackBg.Position               = UDim2.new(0, 0, 0.5, -3)
    trackBg.BackgroundColor3       = Color3.fromRGB(55, 55, 60)
    trackBg.BackgroundTransparency = 0
    trackBg.BorderSizePixel        = 0
    trackBg.Active                 = true
    trackBg.Parent                 = sliderWrapper
    Instance.new("UICorner", trackBg).CornerRadius = UDim.new(1, 0)
    local trackGrad = Instance.new("UIGradient")
    trackGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(35, 35, 38)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(70, 70, 75)),
    })
    trackGrad.Rotation = 0
    trackGrad.Parent   = trackBg
    local fill = Instance.new("Frame")
    fill.Size                   = UDim2.new((curVal - MIN_FLOAT_SIZE) / (MAX_FLOAT_SIZE - MIN_FLOAT_SIZE), 0, 1, 0)
    fill.BackgroundColor3       = Color3.fromRGB(160, 160, 170)
    fill.BackgroundTransparency = 0
    fill.BorderSizePixel        = 0
    fill.ZIndex                 = 2
    fill.Parent                 = trackBg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local thumb = Instance.new("Frame")
    thumb.Size                   = UDim2.new(0, 14, 0, 14)
    thumb.AnchorPoint            = Vector2.new(0.5, 0.5)
    thumb.Position               = UDim2.new((curVal - MIN_FLOAT_SIZE) / (MAX_FLOAT_SIZE - MIN_FLOAT_SIZE), 0, 0.5, 0)
    thumb.BackgroundColor3       = Color3.fromRGB(255, 255, 255)
    thumb.BackgroundTransparency = 0
    thumb.BorderSizePixel        = 0
    thumb.ZIndex                 = 10
    thumb.Active                 = true
    thumb.Parent                 = trackBg
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)
    local sDragging = false
    local sDragInput = nil
    local function applySlider(inputX)
        local abs = trackBg.AbsolutePosition
        local sz  = trackBg.AbsoluteSize
        local rel = math.clamp((inputX - abs.X) / sz.X, 0, 1)
        curVal = math.clamp(math.floor(MIN_FLOAT_SIZE + rel * (MAX_FLOAT_SIZE - MIN_FLOAT_SIZE) + 0.5), MIN_FLOAT_SIZE, MAX_FLOAT_SIZE)
        S_ref.floatBtnSize = curVal
        sizeValueLabel.Text = tostring(S_ref.floatBtnSize)
        local fillRel = (curVal - MIN_FLOAT_SIZE) / (MAX_FLOAT_SIZE - MIN_FLOAT_SIZE)
        fill.Size      = UDim2.new(fillRel, 0, 1, 0)
        thumb.Position = UDim2.new(fillRel, 0, 0.5, 0)
        if S_ref.auraFloatBtn     then S_ref.auraFloatBtn.Size     = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.dropFloatBtn     then S_ref.dropFloatBtn.Size     = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.equipAllFloatBtn then S_ref.equipAllFloatBtn.Size = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.useFloatBtn      then S_ref.useFloatBtn.Size      = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.invisFloatBtn    then S_ref.invisFloatBtn.Size    = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.flyFloatBtn      then S_ref.flyFloatBtn.Size      = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.noclipFloatBtn   then S_ref.noclipFloatBtn.Size   = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
    end
    S_ref.updateFloatSizeVisuals = function(newSize)
        curVal = math.clamp(newSize, MIN_FLOAT_SIZE, MAX_FLOAT_SIZE)
        S_ref.floatBtnSize = curVal
        sizeValueLabel.Text = tostring(S_ref.floatBtnSize)
        local fillRel = (curVal - MIN_FLOAT_SIZE) / (MAX_FLOAT_SIZE - MIN_FLOAT_SIZE)
        fill.Size      = UDim2.new(fillRel, 0, 1, 0)
        thumb.Position = UDim2.new(fillRel, 0, 0.5, 0)
        if S_ref.auraFloatBtn     then S_ref.auraFloatBtn.Size     = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.dropFloatBtn     then S_ref.dropFloatBtn.Size     = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.equipAllFloatBtn then S_ref.equipAllFloatBtn.Size = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.useFloatBtn      then S_ref.useFloatBtn.Size      = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.invisFloatBtn    then S_ref.invisFloatBtn.Size    = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.flyFloatBtn      then S_ref.flyFloatBtn.Size      = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
        if S_ref.noclipFloatBtn   then S_ref.noclipFloatBtn.Size   = UDim2.new(0, S_ref.floatBtnSize, 0, S_ref.floatBtnSize) end
    end
    sliderWrapper.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            if sDragging then return end
            sDragging = true
            sDragInput = input
            applySlider(input.Position.X)
            TS2:Create(thumb, TweenInfo.new(0.08), { Size = UDim2.new(0, 17, 0, 17) }):Play()
        end
    end)
    trackBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            if sDragging then return end
            sDragging = true
            sDragInput = input
            applySlider(input.Position.X)
            TS2:Create(thumb, TweenInfo.new(0.08), { Size = UDim2.new(0, 17, 0, 17) }):Play()
        end
    end)
    UIS_ref.InputChanged:Connect(function(input)
        if not sDragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            applySlider(input.Position.X)
        elseif input.UserInputType == Enum.UserInputType.Touch and input == sDragInput then
            applySlider(input.Position.X)
        end
    end)
    UIS_ref.InputEnded:Connect(function(input)
        if not sDragging then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or (input.UserInputType == Enum.UserInputType.Touch and input == sDragInput) then
            sDragging = false
            sDragInput = nil
            TS2:Create(thumb, TweenInfo.new(0.08), { Size = UDim2.new(0, 14, 0, 14) }):Play()
        end
    end)
end
