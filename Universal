local function doUseTool()
    if S.useCooling then return end
    if not S.feUseInput then return end
    local name = S.feUseInput.Text:match("^%s*(.-)%s*$")
    if name == "" then
        showCustomNotif("StarCrow Says:\n\n   Item name not entered", 3, "fail")
        return
    end
    local char = LocalPlayer.Character
    local human = char and char:FindFirstChildOfClass("Humanoid")
    if not char or not human then
        showCustomNotif("StarCrow Says:\n\n   Character not found", 3, "fail")
        return
    end
    local tool = findUseTool(name)
    if not tool then
        showCustomNotif("StarCrow Says:\n\n   Not found: " .. name, 3, "fail")
        return
    end
    S.useCooling = true
    if S.useFloatBtn then S.useFloatBtn.Text = "..." end
    if tool.Parent == LocalPlayer.Backpack then
        human:EquipTool(tool)
        task.wait(0.12)
    end
    local eq = char:FindFirstChildWhichIsA("Tool")
    if eq and eq.Name:lower() == name:lower() then
        eq:Activate()
    else
        showCustomNotif("StarCrow Says:\n\n   Equip failed", 3, "fail")
    end
    task.wait(0.28)
    if S.useFloatBtn then S.useFloatBtn.Text = "USE" end
    S.useCooling = false
end
