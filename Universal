local function getBestPingValue()
    local ping = nil
    pcall(function()
        local stats = game:GetService("Stats")
        local network = stats:FindFirstChild("Network")
        if not network then return end
        local serverStatsItem = network:FindFirstChild("ServerStatsItem")
        if not serverStatsItem then return end
        local dataPing = serverStatsItem:FindFirstChild("Data Ping")
        if not dataPing then return end
        if typeof(dataPing.GetValue) == "function" then
            local raw = dataPing:GetValue()
            if typeof(raw) == "number" then
                ping = math.floor(raw + 0.5)
                return
            end
        end
        if typeof(dataPing.GetValueString) == "function" then
            local txt = dataPing:GetValueString()
            local n = tonumber(string.match(txt, "%d+"))
            if n then
                ping = n
            end
        end
    end)
    return ping
end
